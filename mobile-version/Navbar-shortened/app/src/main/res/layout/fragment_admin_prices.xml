<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            android:gravity="center"
            android:text="Ride prices"
            android:textColor="@color/profile_bg"
            android:textSize="24sp"
            android:textStyle="bold" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/nav_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <EditText
                    android:id="@+id/etStandardPrice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/whiteish"
                    android:hint="Standard base price"
                    android:inputType="numberDecimal"
                    android:minHeight="48dp"
                    android:textColor="@color/user_input"
                    android:textColorHint="@color/hint_color" />

                <EditText
                    android:id="@+id/etLuxuryPrice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/whiteish"
                    android:hint="Luxury base price"
                    android:inputType="numberDecimal"
                    android:minHeight="48dp"
                    android:textColor="@color/user_input"
                    android:textColorHint="@color/hint_color" />

                <EditText
                    android:id="@+id/etVanPrice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/whiteish"
                    android:hint="Van base price"
                    android:inputType="numberDecimal"
                    android:minHeight="48dp"
                    android:textColor="@color/user_input"
                    android:textColorHint="@color/hint_color" />

                <EditText
                    android:id="@+id/etPerKmPrice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/whiteish"
                    android:hint="Price per km"
                    android:inputType="numberDecimal"
                    android:minHeight="48dp"
                    android:textColor="@color/user_input"
                    android:textColorHint="@color/hint_color" />

                <TextView
                    android:id="@+id/tvPriceError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:textColor="@color/redish"
                    android:textSize="14sp"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/btnSavePrices"
                    style="@style/PrimaryButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Save prices"
                    android:textAllCaps="false" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>